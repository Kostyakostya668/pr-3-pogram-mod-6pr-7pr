<Page x:Class="pr_3_pogram_mod.Pages.SendPassMess"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr_3_pogram_mod.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SendPassMess"
      Background="White">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <StackPanel x:Name="spNameOrEmail" Visibility="Visible" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Введите почту или имя пользователя"/>
            <TextBox x:Name="tbEmailOrName"/>
            <Button x:Name="btEnterEmailOrName" Content="Ввод" Click="btEnterEmailOrName_Click"/>
        </StackPanel>

        <StackPanel x:Name="spCheckCode" Visibility="Hidden" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Введите код отправленный на почту"/>
            <TextBox x:Name="tbCode" TextChanged="tbCode_TextChanged" MaxLength="4"/>
            <Button x:Name="btCode" Content="Ввод" Click="btCode_Click"/>
        </StackPanel>

        <StackPanel x:Name="spNewPass" Visibility="Hidden" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Введите новый пароль"/>
            <TextBox x:Name="tbNewPass"/>
            <TextBlock Text="Повторите пароль"/>
            <TextBox x:Name="tbNewPassAgain"/>
            <Button x:Name="btNewPass" Content="Ввод" Click="btNewPass_Click"/>
        </StackPanel>

    </Grid>
</Page>
