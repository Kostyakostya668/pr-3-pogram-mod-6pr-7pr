<Page x:Class="pr_3_pogram_mod.Pages.CheckTwoAuth"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr_3_pogram_mod.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CheckTwoAuth"
      Background="White">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="270"/>
        </Grid.ColumnDefinitions>

        <StackPanel Visibility="Visible" x:Name="spTwoAuthCheck" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock  Text="Введите код проверки"/>
            <TextBox x:Name="tbTwoAuth" MaxLength="4" TextChanged="tbTwoAuth_TextChanged"/>
            <Button x:Name="btTwoAuth" Content="Ввод" Click="btTwoAuth_Click"/>
        </StackPanel>

    </Grid>
</Page>
